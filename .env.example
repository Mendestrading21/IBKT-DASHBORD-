# ── Configuration ELIO Trading Command Center ──────────────────────────
# Copie ce fichier en « .env » (sans .example) et mets ta vraie clé.
# Le .env est ignoré par git (jamais commité). NE PARTAGE JAMAIS ta clé.

# Clé API Anthropic — active la traduction FR des news + synthèses IA.
# Obtenir une clé : https://console.anthropic.com/  (onglet API Keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sync Notion (notion_sync.py) ───────────────────────────────────────
# Token de l'intégration Notion : https://www.notion.so/my-integrations
# Puis sur la page du cockpit : ⋯ > Connexions > ajoute l'intégration.
NOTION_TOKEN=secret_remplace_moi
